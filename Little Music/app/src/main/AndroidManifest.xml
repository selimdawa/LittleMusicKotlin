<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE" />
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" />
    <uses-permission android:name="android.permission.INTERNET" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@drawable/logo_icon"
        android:label="@string/app_name"
        android:roundIcon="@drawable/logo_icon"
        android:supportsRtl="false"
        android:theme="@style/Base.Theme.MainApp"
        android:usesCleartextTraffic="true"
        tools:replace="android:supportsRtl"
        tools:targetApi="31">
        <activity
            android:name=".activity.SplashActivity"
            android:exported="true"
            android:screenOrientation="portrait">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <activity
            android:name=".activity.MainActivity"
            android:screenOrientation="portrait" />
        <activity
            android:name=".auth.AuthActivity"
            android:screenOrientation="portrait" />
        <activity
            android:name=".auth.ForgetPasswordActivity"
            android:screenOrientation="portrait" />
        <activity
            android:name=".auth.LoginActivity"
            android:screenOrientation="portrait" />
        <activity
            android:name=".auth.RegisterActivity"
            android:screenOrientation="portrait" />
        <activity
            android:name=".activity.PrivacyPolicyActivity"
            android:screenOrientation="portrait" />
        <activity
            android:name=".activity.ProfileActivity"
            android:screenOrientation="portrait" />
        <activity
            android:name=".activity.ProfileEditActivity"
            android:screenOrientation="portrait" />
        <activity
            android:name=".activity.FavoritesActivity"
            android:screenOrientation="portrait" />
        <activity
            android:name=".activity.CategorySongsActivity"
            android:screenOrientation="portrait" />
        <activity
            android:name=".activity.AlbumsActivity"
            android:screenOrientation="portrait" />
        <activity
            android:name=".activity.AlbumSongsActivity"
            android:screenOrientation="portrait" />
        <activity
            android:name=".activity.ArtistsActivity"
            android:screenOrientation="portrait" />
        <activity
            android:name=".activity.ArtistSongsActivity"
            android:screenOrientation="portrait" />
        <activity
            android:name=".activity.ShowMoreActivity"
            android:screenOrientation="portrait" />
        <activity
            android:name=".activity.CategoriesActivity"
            android:screenOrientation="portrait" />
        <activity
            android:name=".activity.MyCategoriesActivity"
            android:screenOrientation="portrait" />
        <activity
            android:name=".activity.MyAlbumsActivity"
            android:screenOrientation="portrait" />
        <activity
            android:name=".activity.MyArtistsActivity"
            android:screenOrientation="portrait" />

        <activity
            android:name="com.theartofdev.edmodo.cropper.CropImageActivity"
            android:screenOrientation="portrait"
            android:theme="@style/Base.Theme.AppCompat" />

    </application>

</manifest>